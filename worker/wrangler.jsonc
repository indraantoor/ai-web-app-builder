{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-web-app-builder-recording",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-07",
  "kv_namespaces": [
    {
      "binding": "METADATA",
